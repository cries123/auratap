# Email Configuration (Resend API)
RESEND_API_KEY=re_replace_with_your_resend_api_key
EMAIL_FROM=support@yourdomain.com

# Your email to receive notifications
ADMIN_EMAIL=support@aurataps.net

# Public site URL used in admin notification emails
ADMIN_URL=http://localhost:5173

# Frontend origin(s) allowed to call this API (comma-separated)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Required for admin dashboard login
ADMIN_PASSWORD=replace-with-strong-admin-password

# Server Port
PORT=3001
